<%# Vista del formulario de registro %>

<%- include('partials/header') %>

<h1 class="page-title">Crear cuenta</h1>

<%# Error si el email ya esta registrado o es invalido %>

<% if (error) { %><p style="color:#e74c3c"><%= error %></p><% } %>

<div class="form-container">
  <form action="/signup" method="POST" class="form">
    <%# Token CSRF (obligatorio en todo form POST) %>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="form-group">
      <label>Email</label>
      <input type="email" name="email" required>
    </div>
    <div class="form-group">
      <label>Contraseña</label>

      <%# minlength del navegador (validacion basica del cliente) %>
      <input type="password" name="password" minlength="6" required>
    </div>
    <div class="form-group">
      <label>Rol</label>
      <select name="role">
        <option value="user">Usuario</option>
        <option value="admin">Administrador</option>
      </select>
    </div>
    <button type="submit" class="btn btn-primary">Registrarse</button>
    <a href="/login" class="btn">Ya tengo cuenta</a>
  </form>
</div>

  </main>
</body>
</html>
