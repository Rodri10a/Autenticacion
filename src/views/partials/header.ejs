<%# Header compartido por todas las vistas %>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Auth</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<% if (authMethod === 'jwt') { %>
<script>
  // Si recien se logueo con JWT, marcar la pestaña como activa
  if (document.cookie.includes('jwt_new=1')) {
    sessionStorage.setItem('jwt_active', '1');
    document.cookie = 'jwt_new=; Max-Age=0; path=/';
  }
  // Si no hay marca, la pestaña fue cerrada y reabierta → logout
  if (!sessionStorage.getItem('jwt_active')) {
    window.location.href = '/jwt-expire';
  }
</script>
<% } %>

  <nav class="navbar">
    <a href="/" class="navbar-brand">Auth</a>
    <div class="navbar-links">
      <%# Si hay usuario logueado muestra email + boton salir %>
      <% if (user) { %>
        <span style="color:#ccc; margin-left:1.5rem;"><%= user.email %></span>
        <%# Logout es POST para que el middleware CSRF valide el token %>
        <form action="/logout" method="POST" class="inline" style="display:inline; margin-left:1.5rem;">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn btn-delete">Salir</button>
        </form>
      <% } else { %>
        <%# Sin login: muestra links a login y signup %>
        <a href="/login">Login</a>
        <a href="/signup">Registro</a>
      <% } %>
    </div>
  </nav>

  <main class="container">
