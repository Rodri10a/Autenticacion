<%- include('partials/header') %>

<h1 class="page-title">Panel de Admin</h1>
<p class="page-subtitle">Ultimos 50 intentos de inicio de sesion</p>

<div class="card">
  <table>
    <tr><th>Email</th><th>Resultado</th><th>Fecha</th></tr>
    <% attempts.forEach(a => { %>
      <tr>
        <td><%= a.email %></td>
        <td><%= a.success ? 'Exitoso' : 'Fallido' %></td>
        <td><%= a.attempted_at %></td>
      </tr>
    <% }) %>
  </table>
</div>

<%- include('partials/footer') %>
